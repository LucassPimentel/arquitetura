@using Order.Application.DTOs.Order
@using Order.Application.Interfaces

@inject IOrderService OrderService
@inject ILogger<CloseOrderForm> Logger

<div class="card">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Fechar Pedido</h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label for="closeOrderId" class="form-label">ID do Pedido *</label>
            <input id="closeOrderId" type="text" class="form-control" @bind="orderIdInput" placeholder="Cole o ID do pedido" />
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-dark" @onclick="HandleSubmit" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Fechando...</span>
                }
                else
                {
                    <span>Fechar Pedido</span>
                }
            </button>
            <button type="button" class="btn btn-secondary" @onclick="ResetForm">Limpar</button>
        </div>

        @if (closedOrder != null)
        {
            <div class="alert alert-success mt-3">
                <strong>Pedido fechado com sucesso!</strong>
                <ul class="mb-0 mt-1">
                    <li>ID: <code>@closedOrder.Id</code></li>
                    <li>Cliente: @closedOrder.ClientId</li>
                    <li>Total: R$ @closedOrder.TotalPrice.ToString("F2")</li>
                    <li>Status: Finalizado</li>
                </ul>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible mt-3">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnOrderClosed { get; set; }

    private string orderIdInput = string.Empty;
    private string errorMessage = string.Empty;
    private bool isSubmitting = false;
    private OrderDto? closedOrder;

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;
        closedOrder = null;

        if (!Guid.TryParse(orderIdInput, out var orderId) || orderId == Guid.Empty)
        {
            errorMessage = "ID do pedido inválido.";
            return;
        }

        try
        {
            isSubmitting = true;
            var result = await OrderService.CloseOrderAsync(orderId);

            if (result.IsSuccess)
            {
                closedOrder = result.Value;
                orderIdInput = string.Empty;
                await OnOrderClosed.InvokeAsync();
            }
            else
            {
                errorMessage = $"Erro ao fechar pedido: {result.Error?.Message}";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Erro ao fechar pedido");
            errorMessage = "Erro inesperado ao fechar pedido.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetForm()
    {
        orderIdInput = string.Empty;
        errorMessage = string.Empty;
        closedOrder = null;
    }
}
